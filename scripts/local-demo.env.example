# Copy this file to scripts/local-demo.env and adjust only if your local paths differ.

# Leave CODE_ROOT unset if project-docs sits alongside the other repos.
# CODE_ROOT=$HOME/code
AUTO_DETECT_HOST_IP=true
# PUBLIC_HOST=
# VERIFIER_PUBLIC_HOST=

# Shared local cert used across auth, issuer, frontend, and verifier HAProxy.
# SHARED_CERT_FILE=${CODE_ROOT}/eudi-srv-web-issuing-eudiw-py/local/runtime/runtime-ec.crt
# SHARED_KEY_FILE=${CODE_ROOT}/eudi-srv-web-issuing-eudiw-py/local/runtime/runtime-ec.key
# Optional full second-stack overrides when you want a second auth/issuer/frontend/verifier stack.
# AUTH_PORT=15001
# ISSUER_PORT=15002
# FRONTEND_PORT=15003
# VERIFIER_STACK_SUFFIX=-ios
# COMPOSE_PROJECT_NAME=ioswalletlocal
# Optional verifier overrides for that second stack.
# VERIFIER_TLS_HOST_PORT=4443
# VERIFIER_BACKEND_HOST_PORT=18080
# VERIFIER_UI_HOST_PORT=14300
# VERIFIER_PUBLIC_URL=https://${VERIFIER_PUBLIC_HOST:-localhost}:4443
# VERIFIER_BACKEND_CONTAINER_NAME=verifier-backend-ios
# VERIFIER_UI_CONTAINER_NAME=verifier-ui-ios
# VERIFIER_HAPROXY_CONTAINER_NAME=verifier-haproxy-ios
# If COMPOSE_PROJECT_NAME is omitted, the wrappers now derive an isolated verifier compose project name automatically for non-default stacks.
# Normal start keeps wallet trust material unchanged.
# The build wrappers sync the current shared cert into the wallet source before compiling.
# Run ./refresh-local-certs.sh --sync-wallet-cert before rebuilding/installing the wallet APK when you intentionally rotate the shared cert outside those wrappers.

# Optional local seed for the Utopia PID signer assets used by issuer mdoc generation.
# Expected files under this directory:
#   privKey/PID-DS-LOCAL-UT.pem
#   cert/PID-DS-LOCAL-UT_cert.der
#   cert/PID-DS-LOCAL-UT_cert.pem
# Legacy PID-DS-0001_UT file names are still accepted as a fallback.
# LOCAL_UTOPIA_SIGNER_SOURCE_DIR=${CODE_ROOT}/some-other-local-issuer/eudi-srv-web-issuing-eudiw-py/local

# Optional if you want device status in smoke checks or install commands in the runbook.
# ANDROID_SDK_DIR=$HOME/Library/Android/sdk
# ADB_BIN=${ANDROID_SDK_ROOT:-${ANDROID_HOME:-$HOME/Library/Android/sdk}}/platform-tools/adb
# ANDROID_SERIAL=RFCNC0JVE3F
# SMOKE_REQUIRE_ANDROID_DEVICE=true

# Optional iOS wallet overrides for the simulator build and smoke scripts.
# IOS_WALLET_REPO=${CODE_ROOT}/eudi-app-ios-wallet-ui
# IOS_PROJECT_FILE=${IOS_WALLET_REPO}/EudiReferenceWallet.xcodeproj
# IOS_SCHEME=EUDI Wallet Dev
# IOS_CONFIGURATION=Debug Dev
# IOS_SIMULATOR_NAME=iPhone 16 Pro
# IOS_DESTINATION=platform=iOS Simulator,name=${IOS_SIMULATOR_NAME}
# IOS_DERIVED_DATA_PATH=${IOS_WALLET_REPO}/.build/DerivedData
# IOS_BUNDLE_ID=eu.europa.ec.euidi.dev
# Set to false only when you intentionally want a simulator build that keeps the hosted defaults.
# IOS_USE_LOCAL_STACK=true

# Local iOS stack overrides. The shared wrappers default these to the active local stack when IOS_USE_LOCAL_STACK=true.
# Use the issuer frontend URL as the local credential_issuer base.
# IOS_LOCAL_ISSUER_URL=${FRONTEND_URL}
# IOS_LOCAL_ISSUER_CLIENT_ID=wallet-dev-local
# Local wallet attestation runs on the auth service in the local stack.
# IOS_LOCAL_WALLET_ATTESTATION_URL=${AUTH_URL}
# Local same-device verifier defaults to the local Docker verifier and preregistered client id.
# IOS_LOCAL_VERIFIER_URL=${VERIFIER_PUBLIC_URL}
# IOS_LOCAL_VERIFIER_CLIENT_ID=Verifier
# Only add hosts that should bypass normal certificate validation for local self-signed TLS.
# IOS_LOCAL_TRUSTED_HOSTS=${PUBLIC_HOST},localhost,127.0.0.1
# Import the shared runtime cert into the simulator root store before smoke runs.
# IOS_INSTALL_LOCAL_ROOT_CERT=true